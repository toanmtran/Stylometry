\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The winning architecture: a single hidden layer of 64 ReLU units feeding a $6$-way softmax (five known authors plus ``none''). Deeper variants stack more 64-unit layers between input and output (Section~\ref {sec:depth}).}}{2}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:arch}{{1}{2}{The winning architecture: a single hidden layer of 64 ReLU units feeding a $6$-way softmax (five known authors plus ``none''). Deeper variants stack more 64-unit layers between input and output (Section~\ref {sec:depth})}{figure.caption.1}{}}
\@writefile{toc}{\contentsline {paragraph}{Training protocol.}{2}{figure.caption.1}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Which features?}{2}{figure.caption.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The 15 most informative features by Random Forest permutation importance (mean drop in held-out accuracy when a feature is shuffled). Punctuation habits (parenthesis, semicolon, colon rates), a vocabulary-richness measure (Honor\'e's $R$), and a handful of function words (\tcbox [on line, colback=codebg, colframe=codebg, boxrule=0pt, arc=2pt, left=2pt, right=2pt, top=0pt, bottom=0pt] {\ttfamily  \small  which}, \tcbox [on line, colback=codebg, colframe=codebg, boxrule=0pt, arc=2pt, left=2pt, right=2pt, top=0pt, bottom=0pt] {\ttfamily  \small  this}, \tcbox [on line, colback=codebg, colframe=codebg, boxrule=0pt, arc=2pt, left=2pt, right=2pt, top=0pt, bottom=0pt] {\ttfamily  \small  would}, \tcbox [on line, colback=codebg, colframe=codebg, boxrule=0pt, arc=2pt, left=2pt, right=2pt, top=0pt, bottom=0pt] {\ttfamily  \small  that}) dominate --- exactly the topic-independent, stylistic signals we want.}}{2}{figure.caption.2}\protected@file@percent }
\newlabel{fig:featimp}{{2}{2}{The 15 most informative features by Random Forest permutation importance (mean drop in held-out accuracy when a feature is shuffled). Punctuation habits (parenthesis, semicolon, colon rates), a vocabulary-richness measure (Honor\'e's $R$), and a handful of function words (\code {which}, \code {this}, \code {would}, \code {that}) dominate --- exactly the topic-independent, stylistic signals we want}{figure.caption.2}{}}
\@writefile{toc}{\contentsline {paragraph}{Model selection on the validation set.}{3}{figure.caption.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Validation accuracy across feature subsets (rows) and network depths (columns). The starred cell --- all 107 features, depth 1 --- is the selected model. Depth 50 sits at $0.171$, barely above the six-class random baseline of $1/6\approx 0.167$.}}{3}{figure.caption.3}\protected@file@percent }
\newlabel{fig:validation}{{3}{3}{Validation accuracy across feature subsets (rows) and network depths (columns). The starred cell --- all 107 features, depth 1 --- is the selected model. Depth 50 sits at $0.171$, barely above the six-class random baseline of $1/6\approx 0.167$}{figure.caption.3}{}}
