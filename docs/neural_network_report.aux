\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Test-set confusion matrix (rows = actual, columns = predicted). The \tcbox [on line, colback=codebg, colframe=codebg, boxrule=0pt, arc=2pt, left=2pt, right=2pt, top=0pt, bottom=0pt] {\ttfamily  \small  none} row and column are perfectly isolated.}}{4}{figure.caption.5}\protected@file@percent }
