\@writefile{toc}{\contentsline {section}{\numberline {2}How Deep Should the Network Be?}{4}{section.2}\protected@file@percent }
\newlabel{sec:depth}{{2}{4}{How Deep Should the Network Be?}{section.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Validation accuracy vs.\ network depth (number of 64-unit hidden layers, log scale). Performance is flat-to-slightly-declining from depth 1 to depth 10, then \textbf  {collapses to chance at depth 50}.}}{5}{figure.caption.6}\protected@file@percent }
\newlabel{fig:depth}{{5}{5}{Validation accuracy vs.\ network depth (number of 64-unit hidden layers, log scale). Performance is flat-to-slightly-declining from depth 1 to depth 10, then \textbf {collapses to chance at depth 50}}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {paragraph}{Are the gradients actually vanishing?}{5}{figure.caption.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Gradient health at initialisation. \textit  {Left}: RMS weight gradient per layer, from the input-facing layer (1) to the output-facing layer, one curve per depth (log scale). \textit  {Right}: the gradient reaching the input-facing first layer as a function of total depth. Both axes are logarithmic.}}{6}{figure.caption.7}\protected@file@percent }
\newlabel{fig:grad}{{6}{6}{Gradient health at initialisation. \textit {Left}: RMS weight gradient per layer, from the input-facing layer (1) to the output-facing layer, one curve per depth (log scale). \textit {Right}: the gradient reaching the input-facing first layer as a function of total depth. Both axes are logarithmic}{figure.caption.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces RMS weight gradient at initialisation, averaged over 50 inits. The first layer (input-facing) is the one that must learn feature combinations; its gradient collapses with depth.}}{6}{table.caption.8}\protected@file@percent }
\newlabel{tab:grad}{{2}{6}{RMS weight gradient at initialisation, averaged over 50 inits. The first layer (input-facing) is the one that must learn feature combinations; its gradient collapses with depth}{table.caption.8}{}}
