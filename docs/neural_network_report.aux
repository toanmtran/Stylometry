\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Gradient health at initialisation. \textit  {Left}: RMS weight gradient per layer, from the input-facing layer (1) to the output-facing layer, one curve per depth (log scale). \textit  {Right}: the gradient reaching the input-facing first layer as a function of total depth. Both axes are logarithmic.}}{7}{figure.caption.9}\protected@file@percent }
\newlabel{fig:grad}{{7}{7}{Gradient health at initialisation. \textit {Left}: RMS weight gradient per layer, from the input-facing layer (1) to the output-facing layer, one curve per depth (log scale). \textit {Right}: the gradient reaching the input-facing first layer as a function of total depth. Both axes are logarithmic}{figure.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces RMS weight gradient at initialisation, averaged over 50 inits. The first layer (input-facing) is the one that must learn feature combinations; its gradient collapses with depth.}}{7}{table.caption.10}\protected@file@percent }
